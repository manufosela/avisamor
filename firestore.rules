rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated (Anonymous Auth)
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is a member of a group
    function isMemberOfGroup(groupId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid));
    }

    // Helper: check if the document belongs to the requesting user
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Groups: read by members, create by authenticated users
    match /groups/{groupId} {
      allow read: if isMemberOfGroup(groupId);
      allow create: if isAuth();
      allow update: if isMemberOfGroup(groupId);
      allow delete: if false;
    }

    // GroupMembers: read by group members, create/update only via server-side (Cloud Functions)
    // R-1 fix: clients cannot self-assign to groups; joinGroup callable handles membership creation
    // R-2 fix: clients cannot mutate role/groupId; only fcmToken update allowed via registerFcmToken callable
    match /groupMembers/{memberId} {
      allow read: if isAuth() &&
        isMemberOfGroup(resource.data.groupId);
      allow create: if false; // Only server-side via Cloud Functions (joinGroup callable)
      allow update: if false; // Only server-side via Cloud Functions (registerFcmToken callable)
      allow delete: if false;
    }

    // Alerts: read by group members, write only via Cloud Functions (server-side)
    match /alerts/{alertId} {
      allow read: if isAuth() &&
        isMemberOfGroup(resource.data.groupId);
      allow create, update, delete: if false;
    }

    // AlertHistory: read-only by group members
    match /alertHistory/{historyId} {
      allow read: if isAuth() &&
        isMemberOfGroup(resource.data.groupId);
      allow create, update, delete: if false;
    }

    // Beacons: read by group members, write only via Cloud Functions (server-side)
    match /beacons/{beaconId} {
      allow read: if isAuth() &&
        isMemberOfGroup(resource.data.groupId);
      allow create, update, delete: if false;
    }

    // ApiKeys: server-side only, no client access
    match /apiKeys/{keyId} {
      allow read, write: if false;
    }
  }
}
